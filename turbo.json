{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:rsbuild": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:vite": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:webpack": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:rsbuild": {
      "cache": false,
      "persistent": true
    },
    "dev:vite": {
      "cache": false,
      "persistent": true
    },
    "dev:webpack": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
