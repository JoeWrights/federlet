{
  "name": "@federlet/vite-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/style-isolation": "workspace:*",
    "@module-federation/vite": "^1.16.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "postcss": "^8.5.15",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*"
  }
}
