{
  "name": "@federlet/mf-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
