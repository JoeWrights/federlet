    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@module-federation/enhanced": "^0.21.6",
    "@federlet/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*"
  }
}
