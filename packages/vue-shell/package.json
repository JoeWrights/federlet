{
  "name": "@federlet/vue-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "vue-tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/mf-runtime": "workspace:*",
    "@federlet/sandbox": "workspace:*",
    "@federlet/shell-core": "workspace:*",
    "@federlet/shared-types": "workspace:*",
    "@federlet/style-isolation": "workspace:*",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*",
    "vue-tsc": "^3.1.8"
  },
  "peerDependencies": {
    "vue": "^3.5.25"
  }
}
