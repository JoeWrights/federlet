{
  "name": "@federlet/shell-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/mf-runtime": "workspace:*",
    "@federlet/shared-types": "workspace:*",
    "@federlet/style-isolation": "workspace:*"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*",
    "vitest": "^2.1.9"
  }
}
