{
  "name": "@federlet/react-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/mf-runtime": "workspace:*",
    "@federlet/shell-core": "workspace:*",
    "@federlet/shared-types": "workspace:*",
    "@federlet/style-isolation": "workspace:*"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "peerDependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
