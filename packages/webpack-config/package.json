{
  "name": "@federlet/webpack-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/style-isolation": "workspace:*",
    "@module-federation/enhanced": "^0.21.6",
    "@swc/core": "^1.15.3",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.5",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "vue-loader": "^17.4.2",
    "webpack": "5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*",
    "@types/node": "^18.19.130",
    "@vue/compiler-sfc": "^3.5.25"
  }
}
