{
  "name": "@federlet/rspack-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/style-isolation": "workspace:*",
    "@module-federation/enhanced": "^0.21.6",
    "@rspack/core": "^1.5.8",
    "css-loader": "^7.1.2",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "vue-loader": "^17.4.2"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*"
  }
}
