{
  "name": "@federlet/rsbuild-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist && node -e \"require('fs').writeFileSync('dist/.keep', '')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@federlet/style-isolation": "workspace:*",
    "@module-federation/enhanced": "^0.21.6",
    "@module-federation/rsbuild-plugin": "^0.21.6",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rsbuild/plugin-vue": "^1.2.9",
    "postcss": "^8.5.15"
  },
  "peerDependencies": {
    "@rspack/core": "~1.7.11"
  },
  "devDependencies": {
    "@federlet/tsconfig": "workspace:*",
    "@rspack/core": "~1.7.11"
  }
}
